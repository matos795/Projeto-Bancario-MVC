@model SistemaBancario.Models.Conta

@{
    ViewData["Title"] = "Sacar da Conta";
}

<h2>Sacar da Conta</h2>

<form asp-action="Sacar" method="post">
    <input type="hidden" asp-for="NumeroConta" />

    <div class="form-group mb-2">
        <label>Nome Usuário</label>
        <input type="text" value="@Model.NomeCliente" class="form-control" readonly />
    </div>

    <div class="form-group mb-2">
        <label>Saldo atual</label>
        <input type="text" value="@Model.Saldo.ToString("C")" class="form-control" readonly />
    </div>

    <div class="form-group mb-2">
        <label asp-for="Saldo" class="control-label">Valor a sacar</label>
        <input type="number" name="novoSaldo" class="form-control" required />
    </div>

    <button type="submit" class="btn btn-success">Sacar</button>
    <a asp-action="Listar" class="btn btn-secondary">Cancelar</a>
</form>